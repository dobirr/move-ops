# Ops Service
NODE_ENV=development
PORT=3002
SERVICE_NAME=ops-service
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://localhost:27017/moveops_ops

# Auth validation
JWT_ACCESS_SECRET=change-me-access-secret

# Public quote flow
PUBLIC_QUOTE_BASE_URL=http://localhost:3005/public/quote
PUBLIC_TOKEN_TTL_DAYS=14

# Upload fallback (MVP)
MAX_PHOTO_URLS=20
